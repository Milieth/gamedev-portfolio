---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Separator from "@/components/bearnie/separator/Separator.astro";
import Card from "@/components/bearnie/card/Card.astro"
import CardContent from "@/components/bearnie/card/CardContent.astro";
import CardHeader from "@/components/bearnie/card/CardHeader.astro";
import CardFooter from "@/components/bearnie/card/CardFooter.astro";
import CardTitle from "@/components/bearnie/card/CardTitle.astro";
import CardDescription from "@/components/bearnie/card/CardDescription.astro";

const isOpen = true;
---

<BaseLayout title="Milieth's Commission Page">
    <div class="flex w-full justify-center">
        {isOpen ? (
            <span class="px-3 py-1 rounded-full backdrop-blur-md border border-white/10 text-2xl font-semibold text-yellow-300 bg-green-600/60">
                Commission Status: Open \(^_^)/
            </span>
        ) : (
            <span class="px-3 py-1 rounded-full backdrop-blur-md border border-white/10 text-2xl font-semibold text-yellow-300 bg-red-600/60">
                Commission Status: Closed
            </span>
        )}
    </div>
    <div class="flex w-full justify-center mt-4">
        <Card class="w-[800px]">
            <CardHeader>
                <CardTitle class="text-4xl text-center">Commission Service</CardTitle>
            </CardHeader>
            <Separator />
            <CardContent class="mt-2">
                <ul class="list-disc list-outside ml-8 marker:text-3xl marker:text-yellow-300 space-y-4">
                    <li>
                        <span class="block text-xl font-bold text-white">Testing Service</span>
                        <p class="text-gray-400 text-sm">A service focused on finding bugs</p>
                        <img 
                            src="/gamedev-portfolio/milestone/testing-services-milestone.png" 
                            alt="Testing Service Milestone" />
                    </li>
                    <li>
                        <span class="block text-xl font-bold text-white">Debugging Service</span>
                        <p class="text-gray-400 text-sm">Fixing existing bugs and optimizing code in your game project.</p>
                    </li>
                    <li>
                        <span class="block text-xl font-bold text-white">Development Service</span>
                        <p class="text-gray-400 text-sm">Developing new features and integrating them seamlessly into existing projects.</p>
                    </li>
                </ul>
            </CardContent>
            <CardFooter>
                <p class="w-full">footnotes</p>
            </CardFooter>
    </div>
</BaseLayout>