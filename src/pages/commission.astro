---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Separator from "@/components/bearnie/separator/Separator.astro";
import Card from "@/components/bearnie/card/Card.astro"
import CardContent from "@/components/bearnie/card/CardContent.astro";
import CardHeader from "@/components/bearnie/card/CardHeader.astro";
import CardFooter from "@/components/bearnie/card/CardFooter.astro";
import CardTitle from "@/components/bearnie/card/CardTitle.astro";
import CardDescription from "@/components/bearnie/card/CardDescription.astro";

const isOpen = true;
---

<BaseLayout title="Milieth's Commission Page">
    <div class="flex w-full justify-center">
        {isOpen ? (
            <span class="px-3 py-1 rounded-full backdrop-blur-md border border-white/10 text-2xl font-semibold text-yellow-300 bg-green-600/60">
                Commission Status: Open \(^_^)/
            </span>
        ) : (
            <span class="px-3 py-1 rounded-full backdrop-blur-md border border-white/10 text-2xl font-semibold text-yellow-300 bg-red-600/60">
                Commission Status: Closed
            </span>
        )}
    </div>
    <div class="flex w-full justify-center mt-8">
        <Card class="w-[800px]">
            <CardHeader>
                <CardTitle class="text-4xl text-center">Commission Service</CardTitle>
            </CardHeader>
            <Separator class="bg-zinc-400" />
            <CardContent class="mt-2">
                <p>Hi! I am here to help, see what I can do for you below:</p>
                <ul class="list-disc list-outside ml-8 marker:text-3xl marker:text-yellow-300 space-y-4">
                    <li>
                        <span class="block text-xl font-bold text-white">Testing Service</span>
                        <p class="text-gray-400 text-sm">A service focused on finding in game bugs, no access to source code is required in 
                            this service. To help you visualize the workflow see milestone:</p>
                        <img 
                            src="/gamedev-portfolio/milestone/testing-services-milestone.png" 
                            alt="Testing Service Milestone" />
                    </li>
                    <li>
                        <span class="block text-xl font-bold text-white">Debugging Service</span>
                        <p class="text-gray-400 text-sm">Fixing existing bugs and optimizing code in your game project.</p>
                        <img 
                            src="/gamedev-portfolio/milestone/debugging-services-milestone.png" 
                            alt="Debugging Service Milestone" />
                    </li>
                    <li>
                        <span class="block text-xl font-bold text-white">Development Service</span>
                        <p class="text-gray-400 text-sm">Developing new features and integrating them into existing projects.</p>
                        <img 
                            src="/gamedev-portfolio/milestone/development-services-milestone.png" 
                            alt="Development Service Milestone" />
                    </li>
                </ul>
            </CardContent>
            <Separator class="bg-zinc-400" />
            <CardContent class="mt-4">
                <h class="text-lg"1>About Waranty Period</h1>
                <p class="text-gray-400 text-sm">Following the final delivery there is waranty period for 7 days.</p>
                <p class="text-gray-400 text-sm"><strong>Included:</strong> Fixes for bugs found in the delivered scope.</p>
                <p class="text-gray-400 text-sm"><strong>Excluded:</strong> New features or unrelated code changes.</p>
            </CardContent>
        </Card>
    </div>
    <div class="flex w-full justify-center mt-8">
        <Card class="w-[800px] text-white">
            <CardHeader>
                <CardTitle class="text-4xl text-center font-extrabold tracking-tight">Pricing and Payment</CardTitle>
            </CardHeader>
            <Separator class="bg-zinc-400" />
            <CardContent class="pt-6">
                <ul class="space-y-8">
                    <li>
                        <div class="flex items-center gap-3 mb-2">
                            <span class="h-2 w-2 rounded-full bg-yellow-300"></span>
                            <h3 class="text-xl font-bold text-white">Pricing</h3>
                        </div>
                        
                        <div class="ml-5">
                            <p class="text-gray-400 text-sm mb-3">Total price is based on these factors:</p>
                            
                            <ol class="list-decimal list-outside ml-5 marker:text-white marker:font-bold">
                                <li class="pl-2">
                                    <span class="text-gray-200">Starter price</span>
                                    <ul class="list-disc list-outside ml-4 m-2 space-y-1 marker:text-yellow-300">
                                        <li class="text-gray-400 text-sm">Testing Service: $10</li>
                                        <li class="text-gray-400 text-sm">Debugging Service: $20</li>
                                        <li class="text-gray-400 text-sm">Development Service: $20</li>
                                    </ul>
                                </li>
                                <li class="pl-2 text-gray-200">Code complexity (high/med/low)</li>
                                <li class="pl-2 text-gray-200">Project or task scale</li>
                            </ol>
                            
                            <p class="text-zinc-500 text-xs italic mt-4 border-l-2 border-zinc-700 pl-3">
                                Note: the price may be negotiable
                            </p>
                        </div>
                    </li>

                    <li>
                        <div class="flex items-center gap-3 mb-2">
                            <span class="h-2 w-2 rounded-full bg-yellow-300"></span>
                            <h3 class="text-xl font-bold text-white">Payment Method</h3>
                        </div>

                        <div class="ml-5 space-y-3">
                            <div>
                                <p class="text-gray-300 uppercase">Payment Platform</p>
                                <img src="/gamedev-portfolio/icons/paypal.svg" 
                                alt="Paypal Icon SVG" 
                                class="w-30 h-30 block ml-4 -my-10"/>
                                <!-- <p class="text-zinc-500 text-xs uppercase tracking-wider font-semibold">Paypal</p> -->
                            </div>
                            
                            <div>
                                <p class="text-gray-300 uppercase">Payment Type</p>
                                <ul class="list-disc list-outside ml-5 space-y-2 marker:text-white">
                                    <li class="text-gray-400 text-sm">
                                        <strong class="text-gray-200">Upfront Payment:</strong> Client pays at the start of each task.
                                    </li>
                                    <li class="text-gray-400 text-sm">
                                        <strong class="text-gray-200">Milestone Based Payment:</strong> Half at the start and the other half before final delivery.
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </li>
                </ul>
            </CardContent>
        </Card>
    </div>
    <div class="flex w-full justify-center mt-8">
        <Card class="w-[800px]">
            <CardHeader>
                <CardTitle class="text-4xl text-center">Confidentiality and Security</CardTitle>
            </CardHeader>
            <Separator class="bg-zinc-400" />
            <CardContent class="mt-2">
                <p>The commissioner commits to maintaining the highest level of confidentiality. Any source code, project designs, or 
                    proprietary information shared by the client will be used solely for the fulfillment of the commission and will not be 
                    shared with third parties.</p>
            </CardContent>
        </Card>
    </div>
</BaseLayout>