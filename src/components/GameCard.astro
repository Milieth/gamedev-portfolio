---
interface Props {
  title: string;
  image: string;
  link: string;
  tags?: { name: string; color: string }[];
}

const {title, image, link, tags = []} = Astro.props;
---

            <div class="relative flex aspect-video items-center justify-center rounded-lg bg-muted overflow-hidden border">
              
              <img src={image} class="h-full w-auto object-contain" alt={title} />

              <div class="absolute top-0 left-0 w-full p-4 bg-gradient-to-b from-black/60 to-transparent text-left">
                <span class="text-2xl font-semibold text-blue-300 drop-shadow-[0_2px_2px_rgba(0,0,0,1)]">
                  {title}
                </span>
              </div>

              <div class="absolute bottom-4 left-4 flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class={`px-3 py-1 rounded-full backdrop-blur-md border border-white/10 text-xs font-medium text-white ${tag.color}`}>
                    {tag.name}
                  </span>
                ))}
              </div>
              <a 
                href={link} 
                class="absolute bottom-4 right-4 flex items-center justify-center bg-blue-600 hover:bg-blue-500 text-white rounded-md transition-all shadow-lg active:scale-95 
                      p-3 
                      sm:px-5 sm:py-2 sm:gap-2"
              >
                <span class="hidden sm:inline text-sm font-bold">
                  Go to game page
                </span>

                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sm:w-4 sm:h-4">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </a>
            </div>
